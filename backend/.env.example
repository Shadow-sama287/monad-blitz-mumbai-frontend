# Backend Environment Configuration

# Server
PORT=4000
NODE_ENV=development

# Monad RPC Configuration
MONAD_RPC_URL=https://testnet-rpc.monadx.io
MONAD_CHAIN_ID=10143

# Smart Contract Addresses (Monad Testnet)
IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
REPUTATION_REGISTRY=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63

# Agent Wallet Private Keys (for signing transactions)
# ⚠️ NEVER commit these to git! Use .env.local or secrets management
JUDGE_PRIVATE_KEY=your_judge_wallet_private_key_here
SERVICE_PRIVATE_KEY=your_service_wallet_private_key_here
CLIENT_PRIVATE_KEY=your_client_wallet_private_key_here

# AI/LLM Configuration (for Judge verdict logic)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo

# Optional: Google GenAI for alternative judge logic
GOOGLE_GENAI_API_KEY=your_google_genai_key_here

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
