# Frontend Environment Variables

# Backend API URL (set to your backend server address)
# For local development: http://localhost:4000
# For production: https://your-backend-domain.com
VITE_BACKEND_URL=http://localhost:4000

# Optional: Enable/disable mock data
# Set to 'false' when backend is ready, 'true' for development
VITE_USE_MOCKS=true

# Monad RPC Configuration
VITE_MONAD_RPC_URL=https://testnet-rpc.monadx.io
VITE_MONAD_CHAIN_ID=10143

# Contract Addresses (Monad Testnet)
VITE_IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
VITE_REPUTATION_REGISTRY=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
